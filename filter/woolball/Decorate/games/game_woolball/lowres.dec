		LOWR MM 3 A_Chase
        LOWR BB 0 A_PlaySound("LOWR_STE")
        LOWR NN 3 A_Chase
        LOWR MM 3 A_Chase
        LOWR CC 0 A_PlaySound("LOWR_STE")
        LOWR NN 3 A_Chase
