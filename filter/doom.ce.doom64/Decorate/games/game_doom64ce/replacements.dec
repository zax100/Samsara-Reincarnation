actor D64MAP22Hack : CustomInventory 254
{
	Game Doom
	+INVENTORY.ALWAYSPICKUP
	+INVENTORY.QUIET
	Inventory.PickupMessage ""
	Inventory.PickupSound ""
	States
	{
	Spawn:
		TNT1 A -1
		Stop
	Pickup:
		TNT1 A 0
		TNT1 A 1 ACS_NamedExecuteAlways("Macro_1")
		Stop
	}
}

