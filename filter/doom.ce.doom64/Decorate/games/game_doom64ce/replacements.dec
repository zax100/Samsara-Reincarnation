actor D64UnmakerUpgrade1_Samsara : CustomInventory replaces D64UnmakerUpgrade1
{
	Radius 20
	Height 16
	Inventory.MaxAmount 1
	Tag "$CC_ARTIFACT1"
	+ALWAYSPICKUP
	+COUNTITEM
	+DONTGIB
	+MOVEWITHSECTOR
	+QUIET
	States
	{
	Spawn:
		ART1 ABCDEDCB 4 Bright
		Loop
	Pickup:
		TNT1 A 0 A_JumpIfInventory("UnmakerUpgrade1Icon",1,"PickupDisplay")
		TNT1 A 0 A_GiveInventory("UnmakerUpgrades")
		TNT1 A 0 A_GiveInventory("SamsaraDoom64UnmakerArtifact")
		TNT1 A 0 A_GiveInventory("UnmakerUpgrade1Icon")
		TNT1 A 0 A_GiveInventory("SamsaraDoom64UnmakerArtifact1Icon")
	PickupDisplay:
		TNT1 A 0 A_JumpIfInventory("DoomClassMode",2,2)
		TNT1 A 0 A_JumpIfInventory("DoomClassMode",1,2)
		TNT1 A 0 A_SpawnItem("SamsaraD64UnmakerUpgrade1PickupMessage")
		Stop
		TNT1 A 0 ACS_NamedExecuteAlways("SamsaraClientMiscPickup", 0, 1, -1, 0)
		Stop
	}
}

actor SamsaraD64UnmakerUpgrade1PickupMessage : Trigger
{
    Inventory.PickupMessage "$GOTARTIFACT1"
    Inventory.PickupSound "misc/d_pkup"
    States
    {
      Pickup:
        goto PickupStop
    }
}

