actor D64AcidMissile2 : D64AcidMissile
{
	States
	{
	Spawn:
		ACIP A 0 Bright
		ACIP A 0 Bright ThrustThingZ(0, 20, 0, 1)
		ACIP A 2 Bright A_SpawnProjectile("D64AcidPuff2", 0, 0, 0, CMF_AIMDIRECTION|CMF_BADPITCH, 0)
		ACIP B 2 Bright A_SpawnProjectile("D64AcidPuff2", 0, 0, 0, CMF_AIMDIRECTION|CMF_BADPITCH, 0)
		ACIP C 2 Bright A_SpawnProjectile("D64AcidPuff2", 0, 0, 0, CMF_AIMDIRECTION|CMF_BADPITCH, 0)
		ACIP D 2 Bright A_SpawnProjectile("D64AcidPuff2", 0, 0, 0, CMF_AIMDIRECTION|CMF_BADPITCH, 0)
	Loopy:
		ACIP D 2 Bright A_SpawnProjectile("D64AcidPuff2", 0, 0, 0, CMF_AIMDIRECTION|CMF_BADPITCH, 0)
		Loop
	Death:
	Crash:
		TNT1 A 1 Bright A_SpawnProjectile("D64RocketSmokeTrail2", 0, 0, 0, CMF_AIMDIRECTION|CMF_BADPITCH, 0)
		Stop
	}
}

actor D64AcidPuff2 : D64AcidPuff
{
	States
	{
	Spawn:
		TNT1 A 2
		ACIP EFGHI 2 BRIGHT
		Stop
	}
}