Actor D64AcidDemon_Samsara : D64Demon_Samsara replaces D64AcidDemon
{
	Health 200
	PainChance 180
	MaxTargetRange 296
	Speed 7
	Radius 24
	Height 56
	Obituary "$OB_ACIDDEMON"
	Tag "Acid Demon"
	BloodColor "00 80 00"
	SpawnID 215
	States
	{
	Spawn:
		ACID AB 10 A_Look
		Loop
	See:
		ACID AABBCCDD 3 Fast A_Chase
		Loop
	Melee:
		TNT1 A 0 A_ChangeFlag("NOPAIN",0)
		ACID EF 8 Fast A_FaceTarget
		ACID G 10 Fast A_SargAttack
		Goto See+1
	Missile:
		TNT1 A 0 A_ChangeFlag("NOPAIN",0)
		TNT1 A 0 A_PlaySound("demon/melee", CHAN_WEAPON)
		ACID EF 8 Fast A_FaceTarget
		TNT1 AAAAAAAAAA 0 A_SpawnProjectile("D64AcidMissile2", random(44,60), random(-8,8), 0, CMF_AIMOFFSET|CMF_BADPITCH)
		ACID G 10 Fast A_FaceTarget
		Goto See+1
	Pain:
		ACID H 2 Fast
		ACID H 2 Fast A_Pain
		Goto See
	Pain.DoomDamageTypeStunner:
		ACID H 2 A_ChangeFlag("NOPAIN",true)
		ACID H 300 A_Pain
		TNT1 A 0 A_ChangeFlag("NOPAIN",false)
		Goto See
	Pain.MightyBoot:
		TNT1 A 0 A_ChangeFlag("NOPAIN",1)
		TNT1 A 0 A_PlaySound("duke/kickhit",CHAN_BODY)
		ACID H 2 A_FaceTarget
		TNT1 A 0 A_Recoil(12)
		ACID H 16 A_Pain
		Goto See
	Death:
		TNT1 A 0 A_SpawnItemEx("UniversalBloodyHellGoreDeathEffect",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION|SXF_USEBLOODCOLOR)
	Death.Massacre:
		ACID I 8 ACS_NamedExecuteAlways("Samsara_KillCount", 0, 0)
		TNT1 AAAAAAAAAAAAAAAA 0 A_SpawnItemEx("D64AcidMissile2", 0, 0, 48, random(-6,6), random(-6,6), random(4,6), random(0,359), 0)
		ACID J 8 A_Scream
		ACID K 4
		ACID L 4 A_NoBlocking
		ACID M 4
		ACID N -1
		Stop
	StakeDeath:
		ACID H 2
		Loop
	Raise:
		ACID A 0
		"####" "#" 0 A_JumpIfInventory("EnemyZorched",1,"ZorchRaise")
		ACID NMLKJI 5
		Goto See
	Pain.ShrinkerDMG:
		ACID G 0
		"####" "#" 0 A_SetUserVar("user_scalex", scalex*65536.0)
		"####" "#" 0 A_SetUserVar("user_scaley", scaley*65536.0)
		"####" "#" 0 A_ChangeFlag("NOPAIN", 1)
		"####" "#" 0 A_ChangeFlag("NODAMAGE", 1)
		"####" "#" 0 A_NoBlocking
		"####" "#" 0 A_PlaySound("duke/shrink")
		"####" "#" 1 A_SetScale(0.95*(user_scalex/65536.0),0.95*(user_scaley/65536.0))
