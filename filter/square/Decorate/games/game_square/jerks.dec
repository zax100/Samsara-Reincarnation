actor PaintJerk_Samsara : CircleJerkBase_Samsara replaces PaintJerk
{
	Health 70
	Obituary "$OB_PAINTJERK"
	Speed 10
	FastSpeed 18
	DropItem "AmmoCase"
	PainChance 160
