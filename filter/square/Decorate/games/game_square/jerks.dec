			"####" "#" 0 ACS_NamedExecuteAlways("SamsaraDeathEffects", 0, 11)
			"####" "#" 0 A_NoBlocking
			"####" "#################" 3 A_FadeOut(0.05,0)
			TNT1 A 0 A_Gravity
			TNT1 A 0 A_JumpIf(args[0] == 1, "GenericDeathItem1")
			TNT1 A 0 A_JumpIf(args[0] == 2, "GenericDeathItem2")
			TNT1 A 0 A_JumpIf(args[0] == 3, "GenericDeathItem3")
			Goto GenericDeathEnd
		Death.DukeIce:
			"####" "#" 0 A_Jump(218,"Ice")
			"####" "#" 0 A_GiveToTarget("DukeKillTaunt",1)
		Ice:
		Death.HexenIce:
		Death.WTMeleeIce:
		Death.WTRangedIce:
