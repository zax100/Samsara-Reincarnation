actor FloppyDiskPassword_Samsara : CustomInventory replaces FloppyDiskPassword
{
	inventory.pickupmessage "$GOTDISKPASSWORD"
	inventory.pickupsound "password/approved"
	Radius 20
	Height 32
    +NOTDMATCH
    +DONTGIB
	+FLOATBOB
	states
	{
		Spawn:
			FLOP A -1
			stop
		Pickup:
			TNT1 A 0 A_GiveInventory("MilitaryID")
			TNT1 A 0 A_GiveInventory("FloppyDiskPassword")
			stop
	}
}

