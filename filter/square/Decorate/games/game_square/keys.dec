actor TriangleKey_Samsara : CustomInventory replaces TriangleKey
{
	inventory.pickupmessage "$GOTKEYTRIANGLE"
	inventory.pickupsound "misc/k_pkup"
	Radius 20
	Height 32
    +NOTDMATCH
    +DONTGIB
	+FLOATBOB
	states
	{
		Spawn:
			TKEY A 10
			TKEY A 10 bright
			loop
		Pickup:
			TNT1 A 0 A_GiveInventory("BaseKey")
			TNT1 A 1 A_GiveInventory("TriangleKey")
			stop
	}
}

