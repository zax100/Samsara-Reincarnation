actor AcolyteShadow2: Acolyte2 replaces AcolyteShadow
{
	ConversationID 61
	+MISSILEMORE
	//+GHOST
	States
	{
	See:
		AGRD A 6 A_BeShadowyFoe
		Goto Acolyte::See+1

	Pain:
		TNT1 A 0 A_SetShadow
		AGRD O 8 Fast Slow A_Pain
		Goto See
	}
}

actor AcolyteToBe2: Acolyte2 replaces AcolyteToBe
{
	ConversationID 29
	Health 61
	Radius 20
	Height 56
	DeathSound "becoming/death"
	-COUNTKILL
	-ISMONSTER
	States
	{
	Spawn:
		ARMR A -1
		Stop

	Pain:
		ARMR A -1 //A_HideDecepticon // Only inherits from AcolyteToBe. Interesting.
		Stop

	Death:
		Goto XDeath

	Death.Massacre:
		Goto XDeath.Massacre

	Death.PunchDagger:
	Death.ElectricBolt:
	Death.PoisonBolt:
	Death.StrifeExplosive:
	Death.StrifeSigil:
		Goto XDeath.PunchDagger
	}
}

