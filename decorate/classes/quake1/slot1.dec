Actor MJLightning
{
    Radius 4
    Height 4
    Projectile
    Speed 20
    RenderStyle Add
    Alpha 0.5
    Scale 0.35
    States
    {
      Spawn:
      Death:
        DPLE B 0
        DPLS B 1 bright ThrustThingZ(0, 32, 1, 0)
        DPLE B 0 A_Stop
        DPLE B 0 bright A_CustomMissile("MjolnirProjectile", 0,0, random(-30,30), CMF_AIMDIRECTION|CMF_TRACKOWNER, 0)
