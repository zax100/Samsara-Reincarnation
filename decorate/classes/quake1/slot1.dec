actor MjolnirDischarge
{
    Projectile
    Radius 8
    Height 8
    DamageType "QuakeElectric"
    ReactionTime 1
    Obituary "$SAMSARA_RANGER_OB_SLOT7B_2"
    //SelfObituary "%o discharges into a liquid." // not just water
    +BLOODLESSIMPACT
    +DONTBLAST
    +DONTREFLECT
    +DONTSPLASH
    +FORCERADIUSDMG
    +NODAMAGETHRUST
    +NOTIMEFREEZE
    +NOTONAUTOMAP
    +NOTRIGGER
    +SKYEXPLODE
    States
    {
      Spawn:
        TNT1 A 1 NoDelay A_Countdown
        loop

      Death:
        TNT1 A 0 A_Explode(18*(ACS_NamedExecuteWithResult("SamsaraDecorate", 5, 1)),4096,0)
        TNT1 A 1 A_Explode(17*(ACS_NamedExecuteWithResult("SamsaraDecorate", 5, 1)),4096)
        stop
    }
}

actor MjolnirDischargeCoop : MjolnirDischarge
{
    Species "Player"
    +THRUSPECIES
}

// Chainsaw

actor SamsaraQuakeChainsawAttackSilentSound : Boolean {}

actor "Q1Chainsaw" : SamsaraQuakeWeapon
{
    Inventory.PickupMessage "You got the Chainsaw."
    Weapon.SelectionOrder 9
    Weapon.Kickback 100
    //Weapon.YAdjust 24
    Obituary "$SAMSARA_RANGER_OB_SLOT1_LOADOUT1"
    Tag "Chainsaw"
    +MELEEWEAPON
    States
    {
      Spawn:
        QSAW Z -1
        stop

      Ready:
        QSAW A 0 A_PlaySound("quakeweps/saw/revving",CHAN_WEAPON)
        QSAW ABCDEABCDEABCDEABCDEABCDEABCDEABCDEABCDE 4 A_WeaponReady //letting the full revving sound play
      ReadyLoop:
        QSAW A 0 A_PlaySound("quakeweps/saw/idle",CHAN_WEAPON)
        QSAW AB 4 A_WeaponReady
      ReadyLoop2:
        QSAW CDE 4 A_WeaponReady
        goto ReadyLoop

      Select:
        TNT1 A 0 A_GiveInventory("Ranger_AxeSelected")
        TNT1 A 0 A_TakeInventory("Ranger_GunSelected")
        TNT1 A 0 A_TakeInventory("Ranger_ExplosiveSelected")
        TNT1 A 0 A_TakeInventory("Ranger_NailSelected")
        TNT1 A 0 A_TakeInventory("Ranger_PlasmaSelected")
        goto Super::Select

      Fire:
        QSAW F 0 A_GiveInventory("SamsaraQuakeWeaponAlert")
        QSAW F 0 A_TakeInventory("SamsaraQuakeChainsawAttackSilentSound")
        QSAW F 0 A_GiveInventory("SamsaraQuakeChainsawAttackHandler")
        QSAW F 4 A_WeaponReady(WRF_NOSWITCH|WRF_NOFIRE)
        QSAW G 0 A_ReFire(1)
        goto FireFinish
        QSAW G 0 A_GiveInventory("SamsaraQuakeWeaponAlert")
        QSAW G 0 A_GiveInventory("SamsaraQuakeChainsawAttackHandler")
        QSAW G 4 A_WeaponReady(WRF_NOSWITCH|WRF_NOFIRE)
        QSAW H 0 A_ReFire(1)
        goto FireFinish
        QSAW H 0 A_GiveInventory("SamsaraQuakeWeaponAlert")
        QSAW H 0 A_GiveInventory("SamsaraQuakeChainsawAttackHandler")
        QSAW H 4 A_WeaponReady(WRF_NOSWITCH|WRF_NOFIRE)
        QSAW I 0 A_ReFire(1)
        goto FireFinish
        QSAW I 0 A_GiveInventory("SamsaraQuakeWeaponAlert")
        QSAW I 0 A_GiveInventory("SamsaraQuakeChainsawAttackHandler")
        QSAW I 4 A_WeaponReady(WRF_NOSWITCH|WRF_NOFIRE)
        QSAW J 0 A_ReFire(1)
        goto FireFinish
        QSAW J 0 A_GiveInventory("SamsaraQuakeWeaponAlert")
        QSAW J 0 A_GiveInventory("SamsaraQuakeChainsawAttackHandler")
        QSAW J 4 A_WeaponReady(WRF_NOSWITCH|WRF_NOFIRE)
        QSAW K 0 A_ReFire(1)
        goto FireFinish
        QSAW K 0 A_GiveInventory("SamsaraQuakeWeaponAlert")
        QSAW K 0 A_GiveInventory("SamsaraQuakeChainsawAttackHandler")
        QSAW K 4 A_WeaponReady(WRF_NOSWITCH|WRF_NOFIRE)
        QSAW F 0 A_ReFire("Fire")
        goto FireFinish

      FireFinish:
        QSAW A 0 A_PlaySound("quakeweps/saw/idle",CHAN_WEAPON)
        QSAW AB 4 A_WeaponReady(WRF_NOSWITCH|WRF_NOFIRE)
        QSAW C 0 A_ReFire
        goto ReadyLoop2
    }
}

actor SamsaraQuakeChainsawAttackHandler : Trigger
{
    States
    {
      // Attack stuff
      Pickup:
        TNT1 A 0 A_JumpIfInventory("SamsaraQuakeChainsawAttackSilentSound",1,2)
        TNT1 A 0 A_PlaySound("quakeweps/saw/attack",CHAN_WEAPON)
        TNT1 A 0 A_JumpIfInventory("SamsaraAlternateSoundToken",2,"PickupOriginal")
        TNT1 A 0 A_JumpIfInventory("SamsaraAlternateSoundToken",1,"PickupRerelease")
      // Original/Deathmatch Classic sounds
      PickupOriginal:
        TNT1 A 0 A_JumpIfInventory("SPModeOn",1,"PickupOriginalCoop")
        TNT1 A 0 A_JumpIfInventory("CoopModeOn",1,"PickupOriginalCoop")
      PickupOriginalDM:
        TNT1 A 0 A_JumpIfInventory("SamsaraHasSpread",1,"PickupOriginalDMSpread")
        TNT1 A 0 A_CustomPunch(20,true,0,"QuakeChainsawPuff")
        goto PickupFinish

      PickupOriginalDMSpread:
        TNT1 A 0 A_CustomPunch(20*3,true,0,"QuakeChainsawPuff")
        goto PickupFinish

      PickupOriginalCoop:
        TNT1 A 0 A_JumpIfInventory("SamsaraHasSpread",1,"PickupOriginalCoopSpread")
        TNT1 A 0 A_CustomPunch(20,true,0,"QuakeChainsawPuffCoop")
        goto PickupFinish

      PickupOriginalCoopSpread:
        TNT1 A 0 A_CustomPunch(20*3,true,0,"QuakeChainsawPuffCoop")
        goto PickupFinish

      // Rerelease sounds
      PickupRerelease:
        TNT1 A 0 A_JumpIfInventory("SPModeOn",1,"PickupRereleaseCoop")
        TNT1 A 0 A_JumpIfInventory("CoopModeOn",1,"PickupRereleaseCoop")
      PickupRereleaseDM:
        TNT1 A 0 A_CustomPunch(20,true,0,"QuakeChainsawPuffSoundRerelease")
        goto PickupFinish

      PickupRereleaseDMSpread:
        TNT1 A 0 A_CustomPunch(20*3,true,0,"QuakeChainsawPuffSoundRerelease")
        goto PickupFinish

      PickupRereleaseCoop:
        TNT1 A 0 A_JumpIfInventory("SamsaraHasSpread",1,"PickupRereleaseCoopSpread")
        TNT1 A 0 A_CustomPunch(20,true,0,"QuakeChainsawPuffCoopSoundRerelease")
        goto PickupFinish

      PickupRereleaseCoopSpread:
        TNT1 A 0 A_CustomPunch(20*3,true,0,"QuakeChainsawPuffCoopSoundRerelease")
        goto PickupFinish

      // Finishing stuff
      PickupFinish:
        TNT1 A 0 A_GiveInventory("SamsaraQuakeChainsawAttackSilentSound")
        stop
    }
}

actor QuakeChainsawPuff : QuakeAxePuff
{
    DamageType "QuakeDamage"
    SeeSound "quakeweps/saw/hit"
    AttackSound "quakeweps/saw/hitwall"
    MeleeSound "quakeweps/saw/hit"
    States
    {
      Spawn:
      Crash:
        TNT1 A 0
        TNT1 A 0 A_PlaySound("quakeweps/saw/hitwall")
        goto SpawnFinish

      Melee:
        TNT1 A 1 A_PlaySound("quakeweps/saw/hit")
        stop
    }
}

actor QuakeChainsawPuffCoop : QuakeChainsawPuff { +MTHRUSPECIES }

actor QuakeChainsawPuffSoundRerelease : QuakeChainsawPuff
{
    AttackSound "quakeweps/rerelease/saw/hitwall"
    States
    {
      Spawn:
      Crash:
        TNT1 A 0
        TNT1 A 0 A_PlaySound("quakeweps/rerelease/saw/hitwall")
        goto SpawnFinish
    }
}

actor QuakeChainsawPuffCoopSoundRerelease : QuakeChainsawPuffSoundRerelease { +MTHRUSPECIES }
