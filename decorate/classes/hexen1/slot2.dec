        Goto DeathFinishSpawner
        TNT1 A 0 A_SpawnItemEx("Hexen_SpearSpike",0,0,0,0,0,-100,0,SXF_TRANSFERPOINTERS|SXF_NOCHECKPOSITION)
      DeathFinishSpawner:
        TNT1 A 1 A_SpawnItemEx("Hexen_FSpearFX5Spawner",0,0,0,0,0,0,0,SXF_CLIENTSIDE)
        stop
      XDeath:
        Goto DeathFinish+1
    }
}

