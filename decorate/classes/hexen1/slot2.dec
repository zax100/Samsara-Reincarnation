// Parias (Reincarnation)

actor "Crusader's Longbow" : SamsaraHexenWeapon
{
    Inventory.PickupMessage "Crusader's Longbow"
    Weapon.SlotNumber 2
    Weapon.SelectionOrder 1700
    Weapon.YAdjust 20
    Weapon.AmmoType "Clip"
    Weapon.AmmoGive 25
    Weapon.AmmoUse 3
    Obituary "$SAMSARA_HEXEN_OB_SLOT2"
    Tag "Crusader's Longbow"
    +BLOODSPLATTER
    +NOALERT
    States
    {
      Spawn:
        H114 A -1
        stop

      Ready:
        H114 BBBFFF 1 A_WeaponReady
        loop

      Deselect:
        H114 B 1 A_Lower
        loop

      Select:
        H114 B 1 A_Raise
        loop

      Fire:
        H114 C 3
        H114 D 3 A_PlaySound("Hexen/BowString",CHAN_WEAPON)
        H114 E 3
      Hold:
        H114 G 1
        TNT1 A 0 A_ReFire
        H114 H 3 A_GiveInventory("SamsaraHexenCrusadersLongbowAttackHandler")
        H114 ICB 3
        goto Ready
    }
}

actor SamsaraHexenCrusadersLongbowAttackHandler : Trigger
{
    States
    {
      // Ammo checking/taking stuff
      Pickup:
        TNT1 A 0 A_JumpIfInventory("SamsaraHasInfiniteAmmo",1,"PickupAttack")
        TNT1 A 0 A_JumpIfInventory("Clip",3,1)
        stop
        TNT1 A 0 A_TakeInventory("Clip",3)
        goto PickupAttack

      // Attack stuff
      PickupAttack:
        TNT1 A 0 A_PlaySound("Hexen/ElectricArrow",CHAN_WEAPON)
        TNT1 A 0 A_JumpIfInventory("PowerSamsaraHexenWeaponLevel2",1,"PickupPowered")
        TNT1 A 0 A_JumpIfInventory("SamsaraHasPermaWeaponLevel2",1,"PickupPowered")
        TNT1 A 0 A_JumpIfInventory("SPModeOn",1,"PickupAttackCoop")
        TNT1 A 0 A_JumpIfInventory("CoopModeOn",1,"PickupAttackCoop")
      PickupAttackDM:
        TNT1 A 0 A_FireCustomMissile("HexenShockArrow",0,false,5,0)
        stop

      PickupAttackCoop:
        TNT1 A 0 A_JumpIfInventory("SamsaraImprovedBalance",1,"PickupAttackCoopImproved")
        TNT1 A 0 A_FireCustomMissile("HexenShockArrow2",0,false,5,0)
        stop

      PickupAttackCoopImproved:
        TNT1 A 0 A_FireCustomMissile("HexenShockArrow2Improved",0,false,5,0)
        stop

      PickupPowered:
        TNT1 A 0 A_JumpIfInventory("SPModeOn",1,"PickupAttackPoweredCoop")
        TNT1 A 0 A_JumpIfInventory("CoopModeOn",1,"PickupAttackPoweredCoop")
      PickupAttackPoweredDM:
        TNT1 A 0 A_FireCustomMissile("HexenShockArrowPowered",0,false,5,0)
        stop

      PickupAttackPoweredCoop:
        TNT1 A 0 A_FireCustomMissile("HexenShockArrowPoweredCoop",0,false,5,0)
        stop
    }
}

actor HexenShockArrow
{
    Projectile
    Radius 5
    Height 5
    Speed 50
    Damage 21
    DamageType "Electric"
    RenderStyle "Add"
    DeathSound "Hexen/ArrowHit"
    Obituary "%o was shocked by one of %k's thunder arrows."
    +BLOODSPLATTER
    +DONTREFLECT
    States
    {
      Spawn:
        H115 A 1 Bright Light("MWAND_X1") A_SpawnItemEx("HexenElectroTrail")
        loop

      Death:
        FAXE R 4 Bright Light("CAXEPUFF1") A_AlertMonsters
        FAXE S 4 Bright Light("CAXEPUFF1")
        FAXE TU 4 Bright Light("CAXEPUFF2")
        FAXE VWX 4 Bright Light("CAXEPUFF3")
        stop
    }
}

actor HexenShockArrow2 : HexenShockArrow
{
    Species "Player"
    +THRUSPECIES
}

actor HexenShockArrow2Improved : HexenShockArrow2 { Damage 24 }

actor HexenElectroTrail
{
    RenderStyle "Add"
    Scale 0.2
    +CLIENTSIDEONLY
    +NOGRAVITY
    States
    {
      Spawn:
        FAXE UVWX 2 Bright
        stop
    }
}

actor HexenShockArrowPowered : HexenShockArrow
{
    +HITTRACER
    States
    {
        XDeath:
            TNT1 A 0 A_SpawnItemEx("LightningCeilingDM",0,0,CallACS("Samsara_Min", ceilingz-z, 100),0,0,0,0,SXF_TRANSFERPOINTERS)
            Goto Super::Death
    }
}

actor HexenShockArrowPoweredCoop : HexenShockArrowPowered
{
    Species "Player"
    +THRUSPECIES
    States
    {
        XDeath:
            TNT1 A 0 A_SpawnItemEx("LightningCeiling2",0,0,CallACS("Samsara_Min", ceilingz-z, 100),0,0,0,0,SXF_TRANSFERPOINTERS)
            Goto Super::Death
    }
}

// Parias (Classic)/Daedolon

actor "Frost Shards" : SamsaraHexenWeapon
{
    Inventory.PickupMessage "Frost Shards"
    Weapon.SlotNumber 2
    Weapon.SelectionOrder 1700
    Weapon.YAdjust 20
    Weapon.AmmoType "Clip"
    Weapon.AmmoGive 25
    Weapon.AmmoUse 2
    Obituary "$SAMSARA_HEXEN_OB_SLOT2"
    Tag "Frost Shards"
    +BLOODSPLATTER
    States
    {
      Spawn:
        WFRS ABC 8 Bright
        loop

      // Parias (Classic)
      Ready:
        TNT1 A 0 A_JumpIfInventory("HexenClassMode",2,"ReadyMage")
      ReadyClericClassic:
        CONE A 1 A_WeaponReady
        goto Ready

      Deselect:
        TNT1 A 0 A_JumpIfInventory("HexenClassMode",2,"DeselectMage")
      DeselectClericClassic:
        CONE A 1 A_Lower
        goto Deselect

      Select:
        TNT1 A 0 A_JumpIfInventory("HexenClassMode",2,"SelectMage")
      SelectClericClassic:
        CONE A 1 A_Raise
        goto Select

      Fire:
        TNT1 A 0 A_JumpIfInventory("HexenClassMode",2,"FireMage")
      FireClericClassic:
        CONE B 3
        CONE C 4
        goto HoldClericClassic

      Hold:
        TNT1 A 0 A_JumpIfInventory("HexenClassMode",2,"HoldMage")
      HoldClericClassic:
        CONE D 3
        CONE E 5 Bright
        CONE F 4 Bright A_GiveInventory("SamsaraHexenFrostShardsAttackHandler")
        CONE G 4
        CONE A 5
        CONE A 7 A_ReFire
        goto Ready

      // Daedolon
      ReadyMage:
        CONE H 1 A_WeaponReady
        goto Ready

      DeselectMage:
        CONE H 1 A_Lower
        goto Deselect

      SelectMage:
        CONE H 1 A_Raise
        goto Select

      FireMage:
        CONE I 3
        CONE J 4
      HoldMage:
        CONE K 3
        CONE L 0 A_JumpIfInventory("PowerSamsaraHexenWeaponLevel2",1,"HoldMagePowered")
        CONE L 0 A_JumpIfInventory("SamsaraHasPermaWeaponLevel2",1,"HoldMagePowered")
        CONE L 5 Bright
        CONE M 4 Bright A_GiveInventory("SamsaraHexenFrostShardsAttackHandler")
        CONE N 4
        CONE H 5
        CONE H 7 A_ReFire
        goto Ready

      HoldMagePowered:
        CONE L 0 A_PlaySound("Hexen/FreezeRay",CHAN_WEAPON,1.0,true)
      HoldMagePowered2:
        CONE L 2 Bright A_GiveInventory("SamsaraHexenFrostShardsAttackPoweredHandler")
        CONE L 0 A_JumpIfInventory("PowerSamsaraHexenWeaponLevel2",1,2)
        CONE L 0 A_JumpIfInventory("SamsaraHasPermaWeaponLevel2",1,1)
        Goto MagePoweredFinish
        CONE L 0 A_JumpIfInventory("Clip",1,1)
        Goto MagePoweredFinish
        CONE L 0 A_Refire("HoldMagePowered2")
      MagePoweredFinish:
        CONE M 4 Bright A_StopSound(CHAN_WEAPON)
        CONE N 4
        CONE H 5
        CONE H 7 A_ReFire
        goto Ready
    }
}

actor SamsaraHexenFrostShardsAttackHandler : Trigger
{
    States
    {
      // Ammo checking/taking stuff
      Pickup:
        TNT1 A 0 A_JumpIfInventory("SamsaraHasInfiniteAmmo",1,"PickupAttack")
        TNT1 A 0 A_JumpIfInventory("Clip",2,1)
        stop
        TNT1 A 0 A_TakeInventory("Clip",2)
        goto PickupAttack

      // Attack stuff
      PickupAttack:
        TNT1 A 0 A_PlaySound("MageShardsFire",CHAN_WEAPON)
        TNT1 A 0 A_JumpIfCloser(92,"PickupAttackMelee")
        goto PickupAttackRanged

      // Melee
      PickupAttackMelee:
        TNT1 A 0 A_JumpIfInventory("SPModeOn",1,"PickupAttackMeleeCoop")
        TNT1 A 0 A_JumpIfInventory("CoopModeOn",1,"PickupAttackMeleeCoop")
      PickupAttackMeleeDM:
        TNT1 A 0 A_FireCustomMissile("FrostMissileMelee",0,false)
        stop

      PickupAttackMeleeCoop:
        TNT1 A 0 A_FireCustomMissile("FrostMissileMeleeCoop",0,false)
        stop

      // Ranged
      // THIS HERE AREA WAS A DICK
      PickupAttackRanged:
        TNT1 A 0 A_JumpIfInventory("SPModeOn",1,"PickupAttackRangedCoop")
        TNT1 A 0 A_JumpIfInventory("CoopModeOn",1,"PickupAttackRangedCoop")
      PickupAttackRangedDM:
      PickupAttackRangedDMPattern1:
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM",14,false,6,1)
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM",9,false,4,1)
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM",5,false,2,1)
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM",-14,false,-6,1)
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM",-9,false,-4,1)
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM",-5,false,-2,1)
      PickupAttackRangedDMPattern2:
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM2",0,false,0,8)
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM3",0,false,0,16)
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM4",0,false,0,24)
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM2",0,false,0,-2)
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM3",0,false,0,-3)
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM4",0,false,0,-4)
      PickupAttackRangedDMPattern3:
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM2",4,false,1,16)
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM2",4,false,1,-2)
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM2",-4,false,-1,16)
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM2",-4,false,-1,-2)
      PickupAttackRangedDMPattern4:
        TNT1 A 0 A_FireCustomMissile("FrostMissileDM",0,false)
        stop

      PickupAttackRangedCoop:
      PickupAttackRangedCoopPattern1:
        TNT1 A 0 A_FireCustomMissile("FrostMissile2",14,false,6,1)
        TNT1 A 0 A_FireCustomMissile("FrostMissile2",9,false,4,1)
        TNT1 A 0 A_FireCustomMissile("FrostMissile2",5,false,2,1)
        TNT1 A 0 A_FireCustomMissile("FrostMissile2",-14,false,-6,1)
        TNT1 A 0 A_FireCustomMissile("FrostMissile2",-9,false,-4,1)
        TNT1 A 0 A_FireCustomMissile("FrostMissile2",-5,false,-2,1)
      PickupAttackRangedCoopPattern2:
        TNT1 A 0 A_FireCustomMissile("FrostMissile2_2",0,false,0,8)
        TNT1 A 0 A_FireCustomMissile("FrostMissile2_3",0,false,0,16)
        TNT1 A 0 A_FireCustomMissile("FrostMissile2_4",0,false,0,24)
        TNT1 A 0 A_FireCustomMissile("FrostMissile2_2",0,false,0,-2)
        TNT1 A 0 A_FireCustomMissile("FrostMissile2_3",0,false,0,-3)
        TNT1 A 0 A_FireCustomMissile("FrostMissile2_4",0,false,0,-4)
      PickupAttackRangedCoopPattern3:
        TNT1 A 0 A_FireCustomMissile("FrostMissile2_2",4,false,1,16)
        TNT1 A 0 A_FireCustomMissile("FrostMissile2_2",4,false,1,-2)
        TNT1 A 0 A_FireCustomMissile("FrostMissile2_2",-4,false,-1,16)
        TNT1 A 0 A_FireCustomMissile("FrostMissile2_2",-4,false,-1,-2)
      PickupAttackRangedCoopPattern4:
        TNT1 A 0 A_FireCustomMissile("FrostMissile2",0,false)
        stop
      // Y'ALL MOTHERFUCKERS BETTER APPRECIATE IT
    }
}

// Melee

actor FrostMissileMelee : FastProjectile
{
    Radius 6
    Height 6
    Speed 20
    Damage (random(90,115)) // Previously 90-115
    DamageType "HexenIce"
    +BLOODLESSIMPACT
    +NOTIMEFREEZE
    States
    {
      Spawn:
        TNT1 AA 1
        stop

      Death:
        TNT1 A 1
        stop
    }
}

actor FrostMissileMeleeCoop : FrostMissileMelee
{
    Species "Player"
    +THRUSPECIES
}

// Ranged

actor FrostMissileDM : FrostMissile
{
    Damage (random(1,6))
    DamageType "HexenIce"
    Obituary "$SAMSARA_HEXEN_OB_SLOT2"
    +BLOODSPLATTER
    +THRUGHOST
    States
    {
      Spawn:
        SHRD A 2 Bright Light("MFROSTSHARD")
        SHRD A 3 Bright Light("MFROSTSHARD") A_ShedShard
        SHRD B 3 Bright Light("MFROSTSHARD")
        SHRD C 3 Bright Light("MFROSTSHARD")
        loop

      Death:
        SHEX A 5 Bright Light("MFROSTSHARD_X1")
        SHEX B 5 Bright Light("MFROSTSHARD_X2")
        SHEX C 5 Bright Light("MFROSTSHARD_X3")
        SHEX D 5 Bright Light("MFROSTSHARD_X4")
        SHEX E 5 Bright
        stop
    }
}

