    }
}

Actor Hexen_SpearSpikeGravitySwitchOff : Trigger
{
    States
    {
        Pickup:
            TNT1 A 0 A_CheckFlag("NOGRAVITY","EnableGravity")
            Stop
        EnableGravity:
            TNT1 A 0 A_GiveInventory("Hexen_SpearSpikeGravitySwitchTracker")
            TNT1 A 0 A_Gravity
            Stop
    }
}

Actor Hexen_SpearSpikeGravitySwitchOn : Trigger
{
    States
    {
        Pickup:
            TNT1 A 0 A_JumpIfInventory("Hexen_SpearSpikeGravitySwitchTracker",1,"DisableGravity")
            Stop
        DisableGravity:
            TNT1 A 0 A_TakeInventory("Hexen_SpearSpikeGravitySwitchTracker")
            TNT1 A 0 A_NoGravity
            Stop
    }
}

Actor Hexen_SpearSpikeGravitySwitchTracker : TemporaryBoolean {}

Actor Hexen_SpearSpike
{
    +ISMONSTER
    -COUNTKILL
    +NODAMAGE
    -SHOOTABLE
    +NODAMAGETHRUST
    Mass 10000000
    Radius 16
    Height 64
    States
    {
        Spawn:
            TSPK E 0 NoDelay A_SetSolid
            TSPK E 0 A_SpawnItemEx("HexenDirtClump")
            TSPK E 0 A_RearrangePointers(AAPTR_NULL,AAPTR_TARGET,AAPTR_DEFAULT)
            TSPK E 0 A_TransferPointer(AAPTR_DEFAULT,AAPTR_DEFAULT,AAPTR_FRIENDPLAYER,AAPTR_MASTER)
            //TODO - this isn't working as expected with flying enemies, we need a better way to check if they reached the floor
            TSPK E 0 A_JumpIfTracerCloser(512,1)
            Goto SpawnFinish
            TSPK E 0 A_GiveInventory("Hexen_SpearSpikeGravitySwitchOff",1,AAPTR_TRACER)
        SpawnLoop:
            TSPK E 2 A_JumpIfTracerCloser(48,"SpawnFinish")
            Loop
        SpawnFinish:
            TSPK E 0 A_GiveInventory("Hexen_SpearSpikeGravitySwitchOn",1,AAPTR_TRACER)
            TSPK E 0 A_PlaySound("Hexen/Spike3",CHAN_BODY)
            TSPK EFGHIJKLMN 3 A_Explode(30,32,XF_NOTMISSILE,false) //We only really need to hurt enemies here
            TSPK E 0 A_PlaySound("Hexen/Spike2",CHAN_5)
            TSPK ANMLKJIHGFE 3
            Stop
    }
}

Actor Hexen_SpearSpikeCoop : Hexen_SpearSpike
{
    Species "Player"
    +THRUSPECIES
}

ACTOR HexenDirtClump : DirtClump
{
    +NOBLOCKMAP
    +NOTELEPORT
    States
    {
        Spawn:
            TSPK C 200
            TSPK C 2 A_Fadeout(0.1)
            Wait
    }
}