// Ranged

actor SamsaraHexenImpalerCrossbowRangedAttackHandler : Trigger
{
    States
    {
      // Attack stuff
      Pickup:
        TNT1 A 0 A_FireBullets(0,0,1,0,"SamsaraBlankPuff",FBF_NORANDOM|FBF_NOFLASH)
        TNT1 A 0 A_JumpIfInventory("PowerSamsaraHexenWeaponLevel2",1,"PickupPowered")
        TNT1 A 0 A_JumpIfInventory("SamsaraHasPermaWeaponLevel2",1,"PickupPowered")
      // Unpowered
      PickupUnpowered:
        TNT1 A 0 A_JumpIfInventory("SPModeOn",1,"PickupUnpoweredCoop")
        TNT1 A 0 A_JumpIfInventory("CoopModeOn",1,"PickupUnpoweredCoop")
      PickupUnpoweredDM:
        TNT1 A 0 A_FireCustomMissile("HexenImpalerMissile",0,false)
        goto PickupFinish

      PickupUnpoweredCoop:
        TNT1 A 0 A_FireCustomMissile("HexenImpalerMissileCoop",0,false)
        goto PickupFinish

      // Powered
      PickupPowered:
        TNT1 A 0 A_JumpIfInventory("SPModeOn",1,"PickupPoweredCoop")
        TNT1 A 0 A_JumpIfInventory("CoopModeOn",1,"PickupPoweredCoop")
      PickupPoweredDM:
        TNT1 A 0 A_FireCustomMissile("HexenImpalerGrapple",0,false)
        goto PickupFinish

      PickupPoweredCoop:
        TNT1 A 0 A_FireCustomMissile("HexenImpalerGrappleCoop",0,false)
        goto PickupFinish

      // Finishing stuff
      PickupFinish:
        TNT1 A 0 A_Recoil(1)
        stop
    }
}

