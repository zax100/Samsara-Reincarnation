    +THRUSPECIES
}

actor HexenImpalerMissileSilent : HexenImpalerMissile { SeeSound "" }
actor HexenImpalerMissileSilentCoop : HexenImpalerMissileCoop { SeeSound "" }

actor HexenImpalerGrapple
{
    Projectile
    Radius 4
    Height 8
    Speed 80
    Damage (random(1,4)*20)
    DamageType "Pistol"
    SeeSound "Hexen/Weapon/XBowFire"
    +BLOODSPLATTER
    +HITTRACER
    States
    {
      Spawn:
        H100 HHHHHHHHHH 1 A_SpawnItemEx("HexenImpalerGrappleChain",0,0,0,sqrt(velx*velx+vely*vely)/80,0,velz/80)
        TNT1 A 0 A_SpawnItemEx("HexenImpalerMissileSilent",0,0,0,velx,vely,velz,0,SXF_ABSOLUTEVELOCITY|SXF_TRANSFERPOINTERS)
        stop

      Death:
      Crash:
        H100 I 3 A_PlaySound("Hexen/Weapon/XBowHit",CHAN_VOICE)
        H100 JKLMN 3
        stop

      XDeath:
        TNT1 A 0 ACS_NamedExecuteWithResult("HexenGrapplePull")
        TNT1 A 1 A_PlaySound("Hexen/Weapon/XBowSplatter",CHAN_VOICE)
        stop
    }
}

actor HexenImpalerGrappleCoop : HexenImpalerGrapple
{
    Species "Player"
    +THRUSPECIES
    States
    {
      Spawn:
        H100 HHHHHHHHHH 1 A_SpawnItemEx("HexenImpalerGrappleChain",0,0,0,sqrt(velx*velx+vely*vely)/80,0,velz/80)
        TNT1 A 0 A_SpawnItemEx("HexenImpalerMissileSilentCoop",0,0,0,velx,vely,velz,0,SXF_ABSOLUTEVELOCITY|SXF_TRANSFERPOINTERS)
        stop
    }
}

actor HexenImpalerGrappleChain
{
    Radius 2
    Height 4
    +CLIENTSIDEONLY
    +NOINTERACTION
    States
    {
      Spawn:
        H100 O 0
        TNT1 A 0 A_SpawnItemEx("HexenImpalerGrappleChain2",-8*sqrt(velx*velx+vely*vely),0,-8*velz)
        TNT1 A 0 A_SpawnItemEx("HexenImpalerGrappleChain2",-16*sqrt(velx*velx+vely*vely),0,-16*velz)
        TNT1 A 0 A_SpawnItemEx("HexenImpalerGrappleChain2",-24*sqrt(velx*velx+vely*vely),0,-24*velz)
        TNT1 A 0 A_SpawnItemEx("HexenImpalerGrappleChain2",-32*sqrt(velx*velx+vely*vely),0,-32*velz)
        TNT1 A 0 A_SpawnItemEx("HexenImpalerGrappleChain2",-40*sqrt(velx*velx+vely*vely),0,-40*velz)
        TNT1 A 0 A_SpawnItemEx("HexenImpalerGrappleChain2",-48*sqrt(velx*velx+vely*vely),0,-48*velz)
        TNT1 A 0 A_SpawnItemEx("HexenImpalerGrappleChain2",-56*sqrt(velx*velx+vely*vely),0,-56*velz)
        TNT1 A 0 A_SpawnItemEx("HexenImpalerGrappleChain2",-64*sqrt(velx*velx+vely*vely),0,-64*velz)
        TNT1 A 0 A_SpawnItemEx("HexenImpalerGrappleChain2",-72*sqrt(velx*velx+vely*vely),0,-72*velz)
        H100 O 12 A_Stop
        stop
    }
}

actor HexenImpalerGrappleChain2 : HexenImpalerGrappleChain
{
    States
    {
      Spawn:
        H100 O 10
        stop
    }
}
